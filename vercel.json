{
  "installCommand": "node -e \"const f=require('fs'),p=require('./package.json');p.dependencies=Object.fromEntries(Object.entries(p.dependencies).filter(([k])=>!/@\\d/.test(k)));f.writeFileSync('package.json',JSON.stringify(p))\" && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist"
}
